{
  "name": "HA React Dashboard",
  "version": "1.0.0",
  "slug": "ha-react-dashboard",
  "description": "Responsive React-based dashboard for Home Assistant with drag-and-drop widgets",
  "url": "https://github.com/thomasv04/ha-react-dashboard",
  "startup": "application",
  "boot": "auto",
  "arch": ["aarch64", "amd64", "armv7"],
  "image": "ghcr.io/thomasv04/ha-react-dashboard/{arch}",
  "ports": {
    "5173/tcp": 5173
  },
  "ports_description": {
    "5173/tcp": "Web UI port"
  },
  "environment": {
    "VITE_HA_URL": "http://homeassistant:8123",
    "VITE_NO_AUTH": "true"
  },
  "options": {
    "port": 5173
  },
  "schema": {
    "port": "port"
  },
  "homeassistant_api": true,
  "privileged": []
}
