# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
*.zip

# Dashboard config — contient des données personnelles (entités HA, config maison)
dashboard_config.json

# SQLite databases (production & test)
data/*.db
data/*.db-shm
data/*.db-wal

# User uploads
data/uploads/

# Stale build artifacts accidentally placed at project root
/assets/

# Environment — never commit secrets
.env
.env.*
!.env.example

# Coverage reports
coverage/

# Playwright reports
playwright-report/
playwright-report-dashboard/
test-results/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Storybook built output (rebuilt in CI)
storybook-static/

# Panel build output — generated during CI, distributed via GitHub Release
custom_components/ha_react_dashboard/www/*
!custom_components/ha_react_dashboard/www/.gitkeep
