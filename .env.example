# ha-react-dashboard — Environment Variables
# Copy this file to .env and fill in your values.

# URL of your Home Assistant instance (no trailing slash)
VITE_HA_URL=http://homeassistant.local:8123

# Long-lived access token generated from HA → Profile → Long-Lived Access Tokens
VITE_HA_TOKEN=

# Folder name used as the deployment path: /local/<VITE_FOLDER_NAME>/
VITE_FOLDER_NAME=ha-dashboard

# SSH deployment (optional — only needed for the deploy script)
# DEPLOY_HOST=192.168.1.x
# DEPLOY_USER=root
# DEPLOY_PATH=/config/www/ha-dashboard
