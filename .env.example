# ha-react-dashboard — Environment Variables
# Copy this file to .env and fill in your values.

# ━━━━━ REQUIRED ━━━━━
# Home Assistant instance URL (no trailing slash)
# Tested with HA 2026.3.0 and later
VITE_HA_URL=http://homeassistant.local:8123

# Long-lived access token from HA → Profile → Long-Lived Access Tokens
# NOT required if VITE_NO_AUTH=true (running as Add-on)
VITE_HA_TOKEN=

# Dashboard folder name (deployment path: /local/<VITE_FOLDER_NAME>/)
VITE_FOLDER_NAME=ha-dashboard

# ━━━━━ OPTIONAL ━━━━━
# Set to 'true' when running as Home Assistant Add-on
# Disables token requirement and uses local HA connection
VITE_NO_AUTH=false

# ━━━━━ SERVER AUTH ━━━━━
# 'ingress'    = HA add-on derrière le reverse proxy HA
# 'standalone' = token Bearer HA (défaut)
# 'disabled'   = pas d'auth (DEV UNIQUEMENT)
HA_AUTH_MODE=standalone
HA_URL=http://supervisor/core
HA_AUTH=true

# ━━━━━ SSH DEPLOYMENT (only for deploy script) ━━━━━
# Hostname/IP of Home Assistant instance for SSH deploy
VITE_SSH_HOSTNAME=192.168.1.100

# SSH username (usually 'root' for HA OS)
VITE_SSH_USERNAME=root

# SSH password
VITE_SSH_PASSWORD=

# Remote deployment path (optional)
# VITE_SSH_DEPLOY_PATH=/config/www/ha-dashboard

